  <diagram name="Page-1" id="neBKbBe3Fgwon3wR3EHG">
    <mxGraphModel dx="1677" dy="773" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle Class Diagram - UC-08: Tạo order cho bàn\n\nclass User {\n  - userId: int\n  - fullName: String\n  - username: String\n  - password: String\n  - role: String\n  - status: String\n  + login(): boolean\n  + createOrder(): Order\n}\n\nclass CoffeeTable {\n  - tableId: int\n  - tableName: String\n  - area: String\n  - status: String\n  + updateStatus(status: String): void\n  + isAvailableForOrder(): boolean\n}\n\nclass Category {\n  - categoryId: int\n  - categoryName: String\n  - description: String\n  + getMenuItems(): List&lt;MenuItem&gt;\n}\n\nclass MenuItem {\n  - itemId: int\n  - itemName: String\n  - price: double\n  - description: String\n  - status: String\n  + isAvailable(): boolean\n  + updateStatus(status: String): void\n}\n\nclass Order {\n  - orderId: int\n  - createdAt: DateTime\n  - status: String\n  - temporaryTotal: double\n  + addItem(item: MenuItem, quantity: int): void\n  + removeItem(itemId: int): void\n  + calculateTotal(): double\n  + updateStatus(status: String): void\n}\n\nclass OrderDetail {\n  - orderDetailId: int\n  - quantity: int\n  - unitPrice: double\n  - subtotal: double\n  + calculateSubtotal(): double\n}\n\nUser \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Order : tạo\nCoffeeTable \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Order : có\nCategory \&quot;1\&quot; --&gt; \&quot;0..*\&quot; MenuItem : phân loại\nOrder \&quot;1\&quot; *-- \&quot;1..*\&quot; OrderDetail : gồm\nMenuItem \&quot;1\&quot; --&gt; \&quot;0..*\&quot; OrderDetail : được chọn trong\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="YN9N0ZiNPtJBS6PWNyts-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
