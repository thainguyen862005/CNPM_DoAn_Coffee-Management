        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle ERD - UC-08: Tạo order cho bàn\n\nentity \&quot;users\&quot; as users {\n  * user_id : INT &lt;&lt;PK&gt;&gt;\n  --\n  full_name : VARCHAR\n  username : VARCHAR\n  password : VARCHAR\n  role : VARCHAR\n  status : VARCHAR\n}\n\nentity \&quot;coffee_tables\&quot; as tables {\n  * table_id : INT &lt;&lt;PK&gt;&gt;\n  --\n  table_name : VARCHAR\n  area : VARCHAR\n  status : VARCHAR\n}\n\nentity \&quot;categories\&quot; as categories {\n  * category_id : INT &lt;&lt;PK&gt;&gt;\n  --\n  category_name : VARCHAR\n  description : VARCHAR\n}\n\nentity \&quot;menu_items\&quot; as menu {\n  * item_id : INT &lt;&lt;PK&gt;&gt;\n  --\n  category_id : INT &lt;&lt;FK&gt;&gt;\n  item_name : VARCHAR\n  price : DECIMAL\n  description : VARCHAR\n  status : VARCHAR\n}\n\nentity \&quot;orders\&quot; as orders {\n  * order_id : INT &lt;&lt;PK&gt;&gt;\n  --\n  table_id : INT &lt;&lt;FK&gt;&gt;\n  user_id : INT &lt;&lt;FK&gt;&gt;\n  created_at : DATETIME\n  status : VARCHAR\n  temporary_total : DECIMAL\n}\n\nentity \&quot;order_details\&quot; as details {\n  * order_detail_id : INT &lt;&lt;PK&gt;&gt;\n  --\n  order_id : INT &lt;&lt;FK&gt;&gt;\n  item_id : INT &lt;&lt;FK&gt;&gt;\n  quantity : INT\n  unit_price : DECIMAL\n  subtotal : DECIMAL\n}\n\nusers ||--o{ orders : \&quot;tạo\&quot;\ntables ||--o{ orders : \&quot;có\&quot;\ncategories ||--o{ menu : \&quot;phân loại\&quot;\norders ||--|{ details : \&quot;gồm\&quot;\nmenu ||--o{ details : \&quot;được chọn trong\&quot;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="SgVhzL97ZYrY9hz8BXNq-1">
